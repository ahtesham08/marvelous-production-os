NEXT_PUBLIC_APP_MODE=demo
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Used by Google Sheets import. Create a Google Cloud service account,
# enable Google Sheets API and Google Drive API, then share both sheets
# with this service account email as Viewer.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Fresh Start Mode default. Keep disabled so old Google Sheets are never modified.
GOOGLE_SHEETS_WRITEBACK_MODE=disabled

NEXT_PUBLIC_APP_URL=http://localhost:3000
